# Important: Never commit your real .env file.

# Local dev (npm run dev:server)
PORT=5432

# Docker: host port for the API container (container listens on 3000)
SERVER_PORT=3001

# Postgres (used by docker-compose db service)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=storycomp
